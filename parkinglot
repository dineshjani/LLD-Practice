  print(f"Spot assigned: {ticket.spot_id}")       # C1 (first car spot found)                                                                                                                                   
  print(f"Ticket ID: {ticket.ticket_id}")         # UUID string                                                                                                                                                 
  print(f"Occupied now: {lot._occupied_spot_ids}")  # {"C1"}                                                                                                                                                    
                                                                                                                                                                                                                
  # Try to enter when only one car spot left                                                                                                                                                                    
