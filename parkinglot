  Step 7: Helper Methods

      def _find_available_spot(self, vehicle_type: VehicleType) -> Optional[ParkingSpot]:
          required_type = self._map_vehicle_to_spot_type(vehicle_type)                                                                                                                                          
          for spot in self._spots:                                                                                                                                                                              
              if (spot.spot_type == required_type                                                                                                                                                               
                      and spot.spot_id not in self._occupied_spot_ids):                                                                                                                                         
                  return spot                                                                                                                                                                                   
          return None
                                                                                                                                                                                                                
      def _map_vehicle_to_spot_type(self, vehicle_type: VehicleType) -> SpotType:
          mapping = {
              VehicleType.MOTORCYCLE: SpotType.MOTORCYCLE,
              VehicleType.CAR: SpotType.CAR,                                                                                                                                                                    
              VehicleType.LARGE: SpotType.LARGE,
          }                                                                                                                                                                                                     
          result = mapping.get(vehicle_type)
          if result is None:                                                                                                                                                                                    
              raise ValueError(f"Unknown vehicle type: {vehicle_type}")
          return result                                                                                                                                                                                         
                  
      def _compute_fee(self, entry_time_ms: int, exit_time_ms: int) -> int:                                                                                                                                     
          duration_ms = exit_time_ms - entry_time_ms
          ms_per_hour = 1000 * 60 * 60                                                                                                                                                                          
                                                                                                                                                                                                                
          # math.ceil handles rounding up: 5 min → 1 hour, 61 min → 2 hours                                                                                                                                     
          hours = math.ceil(duration_ms / ms_per_hour)                                                                                                                                                          
          hours = max(hours, 1)   # minimum 1 hour even if duration_ms == 0                                                                                                                                     
                                                                                                                                                                                                                
          return hours * self._hourly_rate_cents                                                                                                                                                                
                                                                                                                                                                                                                
  Why math.ceil instead of the manual // + remainder check?                                                                                                                                                     
   
  The article's pseudocode does:                                                                                                                                                                                
  hours = duration_ms // ms_per_hour
  if duration_ms % ms_per_hour > 0:                                                                                                                                                                             
      hours += 1                   
  math.ceil(x / y) does exactly the same thing in one line. ceil(2.5) = 3, ceil(3.0) = 3. Cleaner, harder to get wrong.                                                                                         
                  
  Why max(hours, 1)?                                                                                                                                                                                            
   
  If a vehicle enters and exits within milliseconds (test scenario, gate malfunction), ceil(0 / ms_per_hour) = ceil(0) = 0. Charging 0 is probably wrong. Minimum 1 hour charge is the safe default.            
                  
  Why a dict for the mapping instead of if-elif?                                                                                                                                                                
                  
  Dict lookup is O(1) and exhaustive — if you add a new VehicleType.ELECTRIC enum value, the mapping.get() returns None and you get a clear ValueError. With if-elif chains, you might forget to add the new    
  branch and it silently returns None from the function body.
                                                                                                                                                                                                                
