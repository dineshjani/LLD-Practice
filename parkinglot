  Step 11: Extension — Per-Vehicle-Type Pricing

  class FlexPricingParkingLot(ParkingLot):
      def __init__(self, spots: List[ParkingSpot], rates: Dict[VehicleType, int]):                                                                                                                              
          super().__init__(spots, hourly_rate_cents=0)   # base not used                                                                                                                                        
          self._rates = rates     # {VehicleType.MOTORCYCLE: 300, VehicleType.CAR: 500, ...}                                                                                                                    
                                                                                                                                                                                                                
      def _compute_fee(self, entry_time_ms: int, exit_time_ms: int) -> int:                                                                                                                                     
          # Override is called with vehicle_type from the ticket                                                                                                                                                
          raise NotImplementedError("Use _compute_fee_for_vehicle instead")                                                                                                                                     
                                                                                                                                                                                                                
      def exit(self, ticket_id: str) -> int:                                                                                                                                                                    
          if not ticket_id:                                                                                                                                                                                     
              raise ValueError("Ticket ID cannot be empty")
          with self._lock:                                                                                                                                                                                      
              ticket = self._active_tickets.get(ticket_id)
              if ticket is None:                                                                                                                                                                                
                  raise ValueError("Ticket not found or already used")
                                                                                                                                                                                                                
              exit_time_ms = int(time.time() * 1000)
              hours = max(math.ceil((exit_time_ms - ticket.entry_time_ms) / (1000 * 60 * 60)), 1)                                                                                                               
              rate = self._rates.get(ticket.vehicle_type, 500)                                                                                                                                                  
              fee_cents = hours * rate                                                                                                                                                                          
                                                                                                                                                                                                                
              self._occupied_spot_ids.discard(ticket.spot_id)                                                                                                                                                   
              del self._active_tickets[ticket_id]
              return fee_cents                                                                                                                                                                                  
   
  # Usage:                                                                                                                                                                                                      
