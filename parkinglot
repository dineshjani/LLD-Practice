      spots=spots,
      rates={
          VehicleType.MOTORCYCLE: 300,    # $3/hr
          VehicleType.CAR: 500,           # $5/hr                                                                                                                                                               
          VehicleType.LARGE: 800,         # $8/hr
      }                                                                                                                                                                                                         
  )               
                                                                                                                                                                                                                
