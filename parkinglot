  Step 9: Thread Safety Stress Test
                                                                                                                                                                                                                
  import threading
                                                                                                                                                                                                                
  lot2 = ParkingLot(
      spots=[ParkingSpot("C1", SpotType.CAR), ParkingSpot("C2", SpotType.CAR)],
      hourly_rate_cents=500,                                                                                                                                                                                    
  )
                                                                                                                                                                                                                
  results = []                                                                                                                                                                                                  
  errors = []
  barrier = threading.Barrier(5)   # 5 cars, 2 spots — 3 must fail                                                                                                                                              
                                                                                                                                                                                                                
  def try_enter(car_id):                                                                                                                                                                                        
      barrier.wait()   # all threads start simultaneously                                                                                                                                                       
      try:                                                                                                                                                                                                      
          t = lot2.enter(VehicleType.CAR)
          results.append((car_id, t.spot_id))                                                                                                                                                                   
      except ValueError as e:
          errors.append((car_id, str(e)))                                                                                                                                                                       
                  
  threads = [threading.Thread(target=try_enter, args=(i,)) for i in range(5)]                                                                                                                                   
  for t in threads: t.start()
  for t in threads: t.join()                                                                                                                                                                                    
                  
  print(f"Successful bookings: {len(results)}")   # exactly 2                                                                                                                                                   
  print(f"Rejected: {len(errors)}")               # exactly 3
  print(f"Spots booked: {[r[1] for r in results]}")   # ["C1", "C2"] in some order                                                                                                                              
                                                                                                                                                                                                                
  Why threading.Barrier?                                                                                                                                                                                        
  Without it, Thread 0 might finish completely before Thread 1 even starts — no race. The barrier holds all threads until all 5 have called barrier.wait(), then releases them simultaneously. This creates a   
  genuine race on the 2 available spots.                                                                                                                                                                        
  
