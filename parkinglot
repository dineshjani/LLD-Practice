  print(f"Spot: {ticket2.spot_id}")   # C2                                                                                                                                                                      
                                                                                                                                                                                                                
  # ─── Exit after 2.5 hours ────────────────────────────────────────────────────                                                                                                                               
  # Simulate: override entry_time to 2.5 hours ago                                                                                                                                                              
  fake_entry_ms = int(time.time() * 1000) - int(2.5 * 3600 * 1000)                                                                                                                                              
  test_ticket = Ticket(                                                                                                                                                                                         
      ticket_id=ticket.ticket_id,                                                                                                                                                                               
      spot_id=ticket.spot_id,                                                                                                                                                                                   
      vehicle_type=ticket.vehicle_type,
      entry_time_ms=fake_entry_ms,                                                                                                                                                                              
  )
  lot._active_tickets[ticket.ticket_id] = test_ticket   # inject for test                                                                                                                                       
                                                                                                                                                                                                                
  fee = lot.exit(ticket.ticket_id)
  print(f"Fee: {fee} cents = ${fee/100:.2f}")     # 1500 cents = $15.00                                                                                                                                         
