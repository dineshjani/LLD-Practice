  Step 10: Extension — Multi-Floor Garage

  class ParkingFloor:
      def __init__(self, floor_number: int, spots: List[ParkingSpot]):
          self.floor_number = floor_number                                                                                                                                                                      
          self._spots = spots
                                                                                                                                                                                                                
      def find_available_spot(                                                                                                                                                                                  
          self, spot_type: SpotType, occupied_ids: Set[str]
      ) -> Optional[ParkingSpot]:                                                                                                                                                                               
          for spot in self._spots:
              if spot.spot_type == spot_type and spot.spot_id not in occupied_ids:                                                                                                                              
                  return spot
          return None                                                                                                                                                                                           
                  
      def available_count(self, spot_type: SpotType, occupied_ids: Set[str]) -> int:                                                                                                                            
          return sum(
              1 for s in self._spots                                                                                                                                                                            
              if s.spot_type == spot_type and s.spot_id not in occupied_ids                                                                                                                                     
          )
                                                                                                                                                                                                                
                                                                                                                                                                                                                
  class MultiFloorParkingLot(ParkingLot):
      """Extends ParkingLot with floor-aware allocation."""                                                                                                                                                     
                  
      def __init__(self, floors: List[ParkingFloor], hourly_rate_cents: int):                                                                                                                                   
          all_spots = [spot for floor in floors for spot in floor._spots]
          super().__init__(all_spots, hourly_rate_cents)                                                                                                                                                        
          self._floors = floors                                                                                                                                                                                 
  
      def _find_available_spot(self, vehicle_type: VehicleType) -> Optional[ParkingSpot]:                                                                                                                       
          required_type = self._map_vehicle_to_spot_type(vehicle_type)
          # Strategy: fill lower floors first (simplest)                                                                                                                                                        
          for floor in self._floors:                                                                                                                                                                            
              spot = floor.find_available_spot(required_type, self._occupied_spot_ids)                                                                                                                          
              if spot:                                                                                                                                                                                          
                  return spot
          return None

      # Balanced strategy: pick floor with most availability                                                                                                                                                    
      def _find_balanced(self, vehicle_type: VehicleType) -> Optional[ParkingSpot]:
          required_type = self._map_vehicle_to_spot_type(vehicle_type)                                                                                                                                          
          best_floor = max(
              self._floors,                                                                                                                                                                                     
              key=lambda f: f.available_count(required_type, self._occupied_spot_ids),
              default=None,                                                                                                                                                                                     
          )                                                                                                                                                                                                     
          if best_floor and best_floor.available_count(required_type, self._occupied_spot_ids) > 0:
              return best_floor.find_available_spot(required_type, self._occupied_spot_ids)                                                                                                                     
          return None                                                                                                                                                                                           
  
  Spot IDs encode the floor: "3-C5" means floor 3, car spot 5. Ticket never changes — it still stores spot_id. Exit flow is identical.                                                                          
                  
