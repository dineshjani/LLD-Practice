  Step 13: Extensibility — Express Elevator
                                           
  class ExpressElevator(Elevator):
      EXPRESS_FLOORS = {0, 5, 9}                                                                                                                                                                                
                                                                                                                                                                                                                
      def add_request(self, request: Request) -> bool:                                                                                                                                                          
          if request.floor not in self.EXPRESS_FLOORS:                                                                                                                                                          
              return False    # reject non-express floors
          return super().add_request(request)                                                                                                                                                                   
  
                                                                                                                                                                                                                
  class ExpressController(ElevatorController):
      def __init__(self):                                                                                                                                                                                       
          super().__init__(num_elevators=2, num_floors=10)
          self._express = ExpressElevator(elevator_id=99)
                                                                                                                                                                                                                
      def request_elevator(self, floor: int, request_type: RequestType) -> bool:
          if request_type == RequestType.DESTINATION:                                                                                                                                                           
              return False
          if floor < 0 or floor >= self.num_floors:
              return False                                                                                                                                                                                      
  
          with self._lock:                                                                                                                                                                                      
              request = Request(floor, request_type)
              # Express elevator gets priority for express floors when idle
              if (floor in ExpressElevator.EXPRESS_FLOORS                                                                                                                                                       
                      and self._express.direction == Direction.IDLE):                                                                                                                                           
                  return self._express.add_request(request)                                                                                                                                                     
              return self._select_best_elevator(request).add_request(request)                                                                                                                                   
                                                                                                                                                                                                                
      def step(self) -> None:
          with self._lock:                                                                                                                                                                                      
              for e in self._elevators:
                  e.step()                                                                                                                                                                                      
              self._express.step()
                                                                                                                                                                                                                
  No changes to Elevator.step(), Request, or any core algorithm. The override is localized to add_request (filter which floors are accepted) and the controller's dispatch (prefer express elevator for express 
  floors).
                                                                                                                                                                                                                
  ---             
  Step 14: Extensibility — Undo / Cancel a Request
                                                                                                                                                                                                                
      def remove_request(self, request: Request) -> bool:
          """                                                                                                                                                                                                   
          Cancel a queued stop. If elevator already passed or served it,
          this is a no-op (request not in set → discard does nothing).                                                                                                                                          
          """                                                                                                                                                                                                   
          was_present = request in self.requests                                                                                                                                                                
          self.requests.discard(request)                                                                                                                                                                        
          return was_present

  # Usage                                                                                                                                                                                                       
  controller.request_elevator(8, RequestType.PICKUP_UP)
  # ... passenger changes mind                                                                                                                                                                                  
  ticket = Request(8, RequestType.PICKUP_UP)                                                                                                                                                                    
  controller._elevators[0].remove_request(ticket)   # elevator will skip floor 8
                                                                                                                                                                                                                
  Works because state mutations are isolated to add_request/step. The movement algorithm reads self.requests dynamically each tick — removing an entry before the elevator arrives is transparent.              
                                                                                                                                                                                                                
