  Step 8: ElevatorController — Dispatch Logic

  class ElevatorController:
      def __init__(self, num_elevators: int = 3, num_floors: int = 10):
          self.num_floors = num_floors                                                                                                                                                                          
          self._elevators = [Elevator(i) for i in range(num_elevators)]
          self._lock = threading.Lock()                                                                                                                                                                         
                  
      def request_elevator(self, floor: int, request_type: RequestType) -> bool:                                                                                                                                
          """Hall call: someone on a floor pressed UP or DOWN."""
          # Hall calls can only be PICKUP_UP or PICKUP_DOWN                                                                                                                                                     
          if request_type == RequestType.DESTINATION:                                                                                                                                                           
              return False                                                                                                                                                                                      
          if floor < 0 or floor >= self.num_floors:                                                                                                                                                             
              return False                                                                                                                                                                                      
  
          with self._lock:                                                                                                                                                                                      
              request = Request(floor, request_type)
              best = self._select_best_elevator(request)
              return best.add_request(request)                                                                                                                                                                  
  
      def select_floor(self, elevator_id: int, floor: int) -> bool:                                                                                                                                             
          """Passenger inside elevator presses a destination floor button."""
          if floor < 0 or floor >= self.num_floors:                                                                                                                                                             
              return False
          elevator = self._elevators[elevator_id]                                                                                                                                                               
          with self._lock:                                                                                                                                                                                      
              return elevator.add_request(Request(floor, RequestType.DESTINATION))
                                                                                                                                                                                                                
      def step(self) -> None:
          """Advance simulation by one tick."""
          with self._lock:                                                                                                                                                                                      
              for elevator in self._elevators:
                  elevator.step()                                                                                                                                                                               
                  
  ---
  Step 9: Dispatch — Nearest Elevator (Simple → Sophisticated)
                                                                                                                                                                                                                
  Simple: Nearest idle or nearest elevator
                                                                                                                                                                                                                
      def _select_best_elevator(self, request: Request) -> Elevator:
          """                                                                                                                                                                                                   
          Simple strategy: pick the elevator closest to the requested floor.
          Tiebreak: lower elevator_id wins.                                                                                                                                                                     
          """                                                                                                                                                                                                   
          return min(                                                                                                                                                                                           
              self._elevators,                                                                                                                                                                                  
              key=lambda e: (
                  abs(e.current_floor - request.floor),                                                                                                                                                         
                  e.elevator_id,
              ),                                                                                                                                                                                                
          )       

  Sophisticated: Priority tier (what senior candidates discuss)                                                                                                                                                 
  
      def _select_best_elevator(self, request: Request) -> Elevator:                                                                                                                                            
          """     
          Priority tier dispatch (SCAN-aware):
          Tier 1: Elevator already heading toward the request AND will pass it                                                                                                                                  
          Tier 2: Idle elevator, nearest first                                                                                                                                                                  
          Tier 3: Any elevator, nearest first (fallback)                                                                                                                                                        
          """                                                                                                                                                                                                   
          going_right_way = []                                                                                                                                                                                  
          idle = []                                                                                                                                                                                             
                                                                                                                                                                                                                
          for e in self._elevators:
              if self._is_elevator_heading_toward(e, request):                                                                                                                                                  
                  going_right_way.append(e)
              elif e.direction == Direction.IDLE:                                                                                                                                                               
                  idle.append(e)
                                                                                                                                                                                                                
          # Tier 1: elevator en-route in the right direction                                                                                                                                                    
          if going_right_way:
              return min(                                                                                                                                                                                       
                  going_right_way,
                  key=lambda e: abs(e.current_floor - request.floor),
              )                                                                                                                                                                                                 
  
          # Tier 2: idle elevator, pick nearest                                                                                                                                                                 
          if idle:
              return min(
                  idle,
                  key=lambda e: (abs(e.current_floor - request.floor), e.elevator_id),
              )                                                                                                                                                                                                 
  
          # Tier 3: fallback — nearest elevator regardless of state                                                                                                                                             
          return min(
              self._elevators,                                                                                                                                                                                  
              key=lambda e: (abs(e.current_floor - request.floor), e.elevator_id),
          )                                                                                                                                                                                                     
  
      def _is_elevator_heading_toward(self, elevator: 'Elevator', request: Request) -> bool:                                                                                                                    
          """     
          Returns True if this elevator is already moving toward the request
          AND the request floor is still ahead of it.                                                                                                                                                           
          """                                                                                                                                                                                                   
          if elevator.direction == Direction.UP and request.request_type == RequestType.PICKUP_UP:                                                                                                              
              return elevator.current_floor <= request.floor                                                                                                                                                    
          if elevator.direction == Direction.DOWN and request.request_type == RequestType.PICKUP_DOWN:                                                                                                          
              return elevator.current_floor >= request.floor
          return False                                                                                                                                                                                          
                  
  Why tiers?                                                                                                                                                                                                    
  
  Penalty scores (score = distance + some_arbitrary_weight) are fragile — you tune constants for one scenario and break another. Tiers encode real priority: an elevator already going your way and passing your
   floor is always better than any idle elevator, which is always better than a going-the-wrong-way elevator. No magic numbers.
                                                                                                                                                                                                                
