  Step 8 — RateLimiter (Orchestrator)                                                                                                                                                                           
                                                                                                                                                                                                                
  from typing import List, Dict
                                                                                                                                                                                                                
  class RateLimiter:                                                                                                                                                                                          

      def __init__(self, configs: List[dict], default_config: dict):                                                                                                                                            
          factory = LimiterFactory()
                                                                                                                                                                                                                
          # Build endpoint → limiter map                                                                                                                                                                        
          self._limiters: Dict[str, Limiter] = {}
                                                                                                                                                                                                                
          for config in configs:                                                                                                                                                                                
              endpoint = config.get("endpoint")
              if endpoint is None:                                                                                                                                                                              
                  continue  # skip invalid configs silently                                                                                                                                                   
              limiter = factory.create(config)                                                                                                                                                                  
              self._limiters[endpoint] = limiter
                                                                                                                                                                                                                
          # Create default limiter for unknown endpoints                                                                                                                                                        
          self._default_limiter = factory.create(default_config)
                                                                                                                                                                                                                
      def allow(self, client_id: str, endpoint: str) -> RateLimitResult:                                                                                                                                        
          # Look up limiter for this endpoint
          # Fall back to default if endpoint not configured                                                                                                                                                     
          limiter = self._limiters.get(endpoint, self._default_limiter)                                                                                                                                         
  
          # Delegate to the algorithm — pass client_id as the key                                                                                                                                               
          return limiter.allow(client_id)                                                                                                                                                                     
                                                                                                                                                                                                                
  Why pass client_id to limiter.allow(), not endpoint?                                                                                                                                                          
  
  # Rate limiting is PER CLIENT, not per endpoint                                                                                                                                                               
  # The endpoint already determined WHICH limiter to use                                                                                                                                                        
  # The limiter tracks per-client state using client_id as key                                                                                                                                                  
                                                                                                                                                                                                                
  # Flow:                                                                                                                                                                                                       
  # endpoint → selects which limiter (TokenBucket or SlidingWindow)                                                                                                                                           
  # client_id → selects which bucket/log within that limiter                                                                                                                                                    
                                                                                                                                                                                                                
  # Result: each client has independent quota per endpoint                                                                                                                                                      
                                                                                                                                                                                                                
