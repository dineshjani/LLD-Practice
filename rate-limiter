  limiter = SlidingWindowLogLimiter(max_requests=3, window_ms=60000)                                                                                                                                            
  
  # --- t=100000ms ---                                                                                                                                                                                          
  result = limiter.allow("user_123")                                                                                                                                                                          
  # log created: timestamps=deque([])                                                                                                                                                                           
  # cutoff = 100000 - 60000 = 40000                                                                                                                                                                           
  # nothing to remove (empty)                                                                                                                                                                                   
  # count = 0 < 3 → ALLOW
  # append 100000 → timestamps=deque([100000])                                                                                                                                                                  
  # remaining = 3 - 1 = 2                                                                                                                                                                                     
  # Result: allowed=True, remaining=2                                                                                                                                                                           
                                                                                                                                                                                                              
  # --- t=100010ms ---                                                                                                                                                                                          
  result = limiter.allow("user_123")                                                                                                                                                                          
  # cutoff = 100010 - 60000 = 40010
  # 100000 > 40010 → nothing removed                                                                                                                                                                            
  # count = 1 < 3 → ALLOW
  # timestamps=deque([100000, 100010])                                                                                                                                                                          
  # remaining = 3 - 2 = 1                                                                                                                                                                                     
  # Result: allowed=True, remaining=1                                                                                                                                                                           
                                                                                                                                                                                                              
  # --- t=100020ms ---                                                                                                                                                                                          
  result = limiter.allow("user_123")
  # cutoff = 40020, nothing expired                                                                                                                                                                             
  # count = 2 < 3 → ALLOW                                                                                                                                                                                     
  # timestamps=deque([100000, 100010, 100020])                                                                                                                                                                  
  # remaining = 3 - 3 = 0
  # Result: allowed=True, remaining=0                                                                                                                                                                           
                                                                                                                                                                                                              
  # --- t=100030ms ---
  result = limiter.allow("user_123")
  # cutoff = 40030, nothing expired (all timestamps > 40030)                                                                                                                                                    
  # count = 3 = max_requests → DENY                                                                                                                                                                             
  # oldest = 100000                                                                                                                                                                                             
  # retry_after_ms = (100000 + 60000) - 100030 = 160000 - 100030 = 59970ms                                                                                                                                      
  # Result: allowed=False, remaining=0, retry_after_ms=59970                                                                                                                                                    
  
  # --- t=160001ms (60 seconds + 1ms later) ---                                                                                                                                                                 
  result = limiter.allow("user_123")                                                                                                                                                                          
  # cutoff = 160001 - 60000 = 100001                                                                                                                                                                            
  # 100000 < 100001 → REMOVE 100000 from left                                                                                                                                                                   
  # 100010 > 100001 → stop removing
  # timestamps=deque([100010, 100020])                                                                                                                                                                          
  # count = 2 < 3 → ALLOW ✓                                                                                                                                                                                   
  # timestamps=deque([100010, 100020, 160001])                                                                                                                                                                  
  # Result: allowed=True, remaining=0                                                                                                                                                                         
                                                                                                                                                                                                                
  ---                                                                                                                                                                                                         
  Step 7 — LimiterFactory
                                                                                                                                                                                                                
  The factory's job: given raw config dict → return correct Limiter object.
                                                                                                                                                                                                                
  class LimiterFactory:                                                                                                                                                                                       
                                                                                                                                                                                                                
      def create(self, config: dict) -> Limiter:                                                                                                                                                                
          """
          config looks like:                                                                                                                                                                                    
          {                                                                                                                                                                                                   
              "endpoint": "/search",          ← optional (factory ignores this)                                                                                                                                 
              "algorithm": "TokenBucket",     ← required discriminator
              "algoConfig": {                 ← algorithm-specific params                                                                                                                                       
                  "capacity": 1000,                                                                                                                                                                           
                  "refillRatePerSecond": 10                                                                                                                                                                     
              }                                                                                                                                                                                                 
          }
          """                                                                                                                                                                                                   
          algorithm = config.get("algorithm")                                                                                                                                                                 
          algo_config = config.get("algoConfig", {})

          if algorithm == "TokenBucket":                                                                                                                                                                        
              return TokenBucketLimiter(
                  capacity=algo_config["capacity"],                                                                                                                                                             
                  refill_rate_per_second=algo_config["refillRatePerSecond"]                                                                                                                                   
              )                                                                                                                                                                                                 
  
          elif algorithm == "SlidingWindowLog":                                                                                                                                                                 
              return SlidingWindowLogLimiter(                                                                                                                                                                 
                  max_requests=algo_config["maxRequests"],
                  window_ms=algo_config["windowMs"]
              )                                                                                                                                                                                                 
  
          else:                                                                                                                                                                                                 
              raise ValueError(f"Unknown algorithm: {algorithm}")                                                                                                                                             

  Why raise ValueError and not return None?

  # Returning None → caller gets NoneType error later, confusing
  limiter = factory.create({"algorithm": "Unknown"})                                                                                                                                                            
  limiter.allow("user_123")  # AttributeError: 'NoneType' has no 'allow'                                                                                                                                        
  # ← hard to debug, no info about what went wrong                                                                                                                                                              
                                                                                                                                                                                                                
  # Raising ValueError → immediate, clear error at startup                                                                                                                                                      
  # ValueError: Unknown algorithm: Unknown                                                                                                                                                                      
  # ← clear, points exactly to the problem                                                                                                                                                                      
  
  Pattern used: Switch/dispatch on discriminator field                                                                                                                                                          
                                                                                                                                                                                                              
  # "algorithm" field is the DISCRIMINATOR — tells us which class to create                                                                                                                                     
  # "algoConfig" is HETEROGENEOUS — different fields per algorithm                                                                                                                                              
                                                                                                                                                                                                                
  # This is the classic Factory pattern:                                                                                                                                                                        
  # Same interface (Limiter), different implementations,                                                                                                                                                        
  # runtime decision based on config data                                                                                                                                                                       
                                                                                                                                                                                                                
