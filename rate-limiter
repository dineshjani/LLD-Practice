  Step 9 — Complete Working Code (All Together)                                                                                                                                                               
                                                                                                                                                                                                                
  import time
  import math                                                                                                                                                                                                   
  from abc import ABC, abstractmethod                                                                                                                                                                         
  from collections import deque
  from dataclasses import dataclass, field
  from typing import Dict, List, Optional
                                                                                                                                                                                                                
  
  # ─────────────────────────────────────────                                                                                                                                                                   
  # RESULT VALUE OBJECT                                                                                                                                                                                       
  # ─────────────────────────────────────────                                                                                                                                                                   
  
  @dataclass(frozen=True)                                                                                                                                                                                       
  class RateLimitResult:                                                                                                                                                                                      
      allowed: bool
      remaining: int
      retry_after_ms: Optional[int]                                                                                                                                                                             
  
                                                                                                                                                                                                                
  # ─────────────────────────────────────────                                                                                                                                                                 
  # LIMITER INTERFACE
  # ─────────────────────────────────────────
                                                                                                                                                                                                                
  class Limiter(ABC):
      @abstractmethod                                                                                                                                                                                           
      def allow(self, key: str) -> RateLimitResult:                                                                                                                                                           
          pass

                                                                                                                                                                                                                
  # ─────────────────────────────────────────
  # TOKEN BUCKET ALGORITHM                                                                                                                                                                                      
  # ─────────────────────────────────────────                                                                                                                                                                 

  @dataclass
  class TokenBucket:
      tokens: float                                                                                                                                                                                             
      last_refill_time: float
                                                                                                                                                                                                                
                                                                                                                                                                                                              
  class TokenBucketLimiter(Limiter):

      def __init__(self, capacity: int, refill_rate_per_second: int):                                                                                                                                           
          self.capacity = capacity
          self.refill_rate = refill_rate_per_second                                                                                                                                                             
          self.buckets: Dict[str, TokenBucket] = {}                                                                                                                                                           

      def _now(self) -> float:                                                                                                                                                                                  
          return time.time() * 1000
                                                                                                                                                                                                                
      def _get_or_create_bucket(self, key: str) -> TokenBucket:                                                                                                                                               
          if key not in self.buckets:
              self.buckets[key] = TokenBucket(                                                                                                                                                                  
                  tokens=self.capacity,
                  last_refill_time=self._now()                                                                                                                                                                  
              )                                                                                                                                                                                               
          return self.buckets[key]

      def allow(self, key: str) -> RateLimitResult:                                                                                                                                                             
          bucket = self._get_or_create_bucket(key)
                                                                                                                                                                                                                
          now = self._now()                                                                                                                                                                                   
          elapsed_ms = now - bucket.last_refill_time
          tokens_to_add = (elapsed_ms * self.refill_rate) / 1000                                                                                                                                                
          bucket.tokens = min(self.capacity, bucket.tokens + tokens_to_add)
          bucket.last_refill_time = now                                                                                                                                                                         
                                                                                                                                                                                                              
          if bucket.tokens >= 1:                                                                                                                                                                                
              bucket.tokens -= 1                                                                                                                                                                              
              return RateLimitResult(
                  allowed=True,                                                                                                                                                                                 
                  remaining=int(bucket.tokens),
                  retry_after_ms=None                                                                                                                                                                           
              )                                                                                                                                                                                               
          else:
              tokens_needed = 1 - bucket.tokens
              retry_after_ms = math.ceil(
                  (tokens_needed / self.refill_rate) * 1000                                                                                                                                                     
              )
              return RateLimitResult(                                                                                                                                                                           
                  allowed=False,                                                                                                                                                                              
                  remaining=0,
                  retry_after_ms=retry_after_ms
              )                                                                                                                                                                                                 
  
                                                                                                                                                                                                                
  # ─────────────────────────────────────────                                                                                                                                                                 
  # SLIDING WINDOW LOG ALGORITHM
  # ─────────────────────────────────────────

  @dataclass
  class RequestLog:
      timestamps: deque = field(default_factory=deque)                                                                                                                                                          
  
                                                                                                                                                                                                                
  class SlidingWindowLogLimiter(Limiter):                                                                                                                                                                     

      def __init__(self, max_requests: int, window_ms: int):
          self.max_requests = max_requests
          self.window_ms = window_ms                                                                                                                                                                            
          self.logs: Dict[str, RequestLog] = {}
                                                                                                                                                                                                                
      def _now(self) -> int:                                                                                                                                                                                    
          return int(time.time() * 1000)
                                                                                                                                                                                                                
      def _get_or_create_log(self, key: str) -> RequestLog:                                                                                                                                                   
          if key not in self.logs:
              self.logs[key] = RequestLog()
          return self.logs[key]                                                                                                                                                                                 
  
      def allow(self, key: str) -> RateLimitResult:                                                                                                                                                             
          log = self._get_or_create_log(key)                                                                                                                                                                  
          now = self._now()
          cutoff = now - self.window_ms                                                                                                                                                                         
  
          # Remove expired timestamps                                                                                                                                                                           
          while log.timestamps and log.timestamps[0] < cutoff:                                                                                                                                                
              log.timestamps.popleft()

          if len(log.timestamps) < self.max_requests:                                                                                                                                                           
              log.timestamps.append(now)
              remaining = self.max_requests - len(log.timestamps)                                                                                                                                               
              return RateLimitResult(                                                                                                                                                                           
                  allowed=True,
                  remaining=remaining,                                                                                                                                                                          
                  retry_after_ms=None                                                                                                                                                                         
              )
          else:
              oldest = log.timestamps[0]
              retry_after_ms = (oldest + self.window_ms) - now
              return RateLimitResult(                                                                                                                                                                           
                  allowed=False,
                  remaining=0,                                                                                                                                                                                  
                  retry_after_ms=retry_after_ms                                                                                                                                                               
              )

                                                                                                                                                                                                                
  # ─────────────────────────────────────────
  # FACTORY                                                                                                                                                                                                     
  # ─────────────────────────────────────────                                                                                                                                                                 

  class LimiterFactory:

      def create(self, config: dict) -> Limiter:
          algorithm = config.get("algorithm")
          algo_config = config.get("algoConfig", {})                                                                                                                                                            
  
          if algorithm == "TokenBucket":                                                                                                                                                                        
              return TokenBucketLimiter(                                                                                                                                                                      
                  capacity=algo_config["capacity"],
                  refill_rate_per_second=algo_config["refillRatePerSecond"]
              )                                                                                                                                                                                                 
          elif algorithm == "SlidingWindowLog":
              return SlidingWindowLogLimiter(                                                                                                                                                                   
                  max_requests=algo_config["maxRequests"],                                                                                                                                                      
                  window_ms=algo_config["windowMs"]
              )                                                                                                                                                                                                 
          else:                                                                                                                                                                                               
              raise ValueError(f"Unknown algorithm: {algorithm}")

                                                                                                                                                                                                                
  # ─────────────────────────────────────────
  # RATE LIMITER (ORCHESTRATOR)                                                                                                                                                                                 
  # ─────────────────────────────────────────                                                                                                                                                                 

  class RateLimiter:

      def __init__(self, configs: List[dict], default_config: dict):                                                                                                                                            
          factory = LimiterFactory()
          self._limiters: Dict[str, Limiter] = {}                                                                                                                                                               
                                                                                                                                                                                                              
          for config in configs:
              endpoint = config.get("endpoint")
              if endpoint is None:
                  continue                                                                                                                                                                                      
              self._limiters[endpoint] = factory.create(config)
                                                                                                                                                                                                                
          self._default_limiter = factory.create(default_config)                                                                                                                                              

      def allow(self, client_id: str, endpoint: str) -> RateLimitResult:                                                                                                                                        
          limiter = self._limiters.get(endpoint, self._default_limiter)
          return limiter.allow(client_id)                                                                                                                                                                       
                                                                                                                                                                                                                
