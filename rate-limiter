  Step 3 — RateLimitResult (Start Here, It's Simplest)                                                                                                                                                        
                                                                                                                                                                                                                
  from dataclasses import dataclass
  from typing import Optional                                                                                                                                                                                   
                                                                                                                                                                                                              
  @dataclass(frozen=True)   # frozen=True makes it immutable                                                                                                                                                    
  class RateLimitResult:                                                                                                                                                                                      
      allowed: bool
      remaining: int
      retry_after_ms: Optional[int]  # None when allowed, int when denied                                                                                                                                       
  
  Why dataclass?                                                                                                                                                                                                
                                                                                                                                                                                                              
  # Without dataclass — verbose                                                                                                                                                                                 
  class RateLimitResult:                                                                                                                                                                                      
      def __init__(self, allowed, remaining, retry_after_ms):
          self.allowed = allowed                                                                                                                                                                                
          self.remaining = remaining
          self.retry_after_ms = retry_after_ms                                                                                                                                                                  
                                                                                                                                                                                                              
  # With dataclass — clean, auto-generates __init__, __repr__, __eq__                                                                                                                                           
  @dataclass(frozen=True)
  class RateLimitResult:                                                                                                                                                                                        
      allowed: bool                                                                                                                                                                                           
      remaining: int                                                                                                                                                                                            
      retry_after_ms: Optional[int]
                                                                                                                                                                                                                
  Why frozen=True?                                                                                                                                                                                            

  # frozen=True prevents mutation after creation
  result = RateLimitResult(allowed=True, remaining=99, retry_after_ms=None)                                                                                                                                     
  result.allowed = False   # raises FrozenInstanceError — good!
                                                                                                                                                                                                                
  # Rate limit decisions should NEVER be modified after creation                                                                                                                                                
  # Immutability prevents bugs where something accidentally changes the result                                                                                                                                  
                                                                                                                                                                                                                
  Usage:                                                                                                                                                                                                      
  # Creating results                                                                                                                                                                                            
  success = RateLimitResult(allowed=True, remaining=99, retry_after_ms=None)                                                                                                                                  
  denied  = RateLimitResult(allowed=False, remaining=0, retry_after_ms=800) 
                                                                                                                                                                                                                
  # Reading results                                                                                                                                                                                             
  if result.allowed:                                                                                                                                                                                            
      forward_request()                                                                                                                                                                                         
  else:                                                                                                                                                                                                       
      return 429, f"Retry after {result.retry_after_ms}ms"

