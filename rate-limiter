  Step 11 — Thread Safety Extension (For SDE-2 Level)
                                                                                                                                                                                                                
  import threading
                                                                                                                                                                                                                
  class TokenBucketLimiter(Limiter):                                                                                                                                                                            
  
      def __init__(self, capacity: int, refill_rate_per_second: int):                                                                                                                                           
          self.capacity = capacity                                                                                                                                                                            
          self.refill_rate = refill_rate_per_second
          self.buckets: Dict[str, TokenBucket] = {}
          self._map_lock = threading.Lock()  # protects bucket creation
                                                                                                                                                                                                                
      def _get_or_create_bucket(self, key: str) -> TokenBucket:
          # Lock only for creation — not for the allow logic                                                                                                                                                    
          with self._map_lock:                                                                                                                                                                                  
              if key not in self.buckets:
                  self.buckets[key] = TokenBucket(                                                                                                                                                              
                      tokens=self.capacity,                                                                                                                                                                   
                      last_refill_time=self._now(),                                                                                                                                                             
                      lock=threading.Lock()   # each bucket has own lock                                                                                                                                      
                  )                                                                                                                                                                                             
              return self.buckets[key]
                                                                                                                                                                                                                
      def allow(self, key: str) -> RateLimitResult:                                                                                                                                                           
          bucket = self._get_or_create_bucket(key)
                                                                                                                                                                                                                
          # Lock per BUCKET not globally
          # user_123 and user_456 can run concurrently                                                                                                                                                          
          # only same user blocks same user                                                                                                                                                                     
          with bucket.lock:                                                                                                                                                                                     
              now = self._now()                                                                                                                                                                                 
              elapsed_ms = now - bucket.last_refill_time                                                                                                                                                        
              tokens_to_add = (elapsed_ms * self.refill_rate) / 1000                                                                                                                                          
              bucket.tokens = min(self.capacity, bucket.tokens + tokens_to_add)                                                                                                                                 
              bucket.last_refill_time = now
                                                                                                                                                                                                                
              if bucket.tokens >= 1:                                                                                                                                                                          
                  bucket.tokens -= 1
                  allowed, remaining, retry_after_ms = True, int(bucket.tokens), None                                                                                                                           
              else:
                  tokens_needed = 1 - bucket.tokens                                                                                                                                                             
                  retry_ms = math.ceil((tokens_needed / self.refill_rate) * 1000)                                                                                                                               
                  allowed, remaining, retry_after_ms = False, 0, retry_ms
                                                                                                                                                                                                                
          # Create result OUTSIDE lock — no need to hold lock for this                                                                                                                                          
          return RateLimitResult(allowed, remaining, retry_after_ms)                                                                                                                                            
                                                                                                                                                                                                                
                                                                                                                                                                                                              
  @dataclass
  class TokenBucket:
      tokens: float                                                                                                                                                                                             
      last_refill_time: float
      lock: threading.Lock = field(default_factory=threading.Lock)                                                                                                                                              
                                                                                                                                                                                                              
