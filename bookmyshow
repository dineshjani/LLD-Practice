  Step 5: Hold Seat (Click "Select")

      def hold_seats(self, seat_labels: List[str], user_id: str) -> Optional[SeatHold]:
          """
          Atomically try to place a temporary hold on all requested seats.
          Returns SeatHold on success, None if any seat is unavailable.
          """
          with self._lock:
              # Step 1: Expire stale holds before checking availability
              self._expire_holds()

              # Step 2: Check ALL seats are available (all-or-nothing)
              for label in seat_labels:
                  if label not in self._seats:
                      return None  # seat doesn't exist
                  if self._seat_status[label] != SeatStatus.AVAILABLE:
                      return None  # seat already held/booked

              # Step 3: Place hold on all seats atomically
              held_until = datetime.now() + timedelta(minutes=self.hold_duration_minutes)

              # We store one hold per seat for simplicity
              # In production you'd batch them under one hold_id per user request
              hold_id = str(uuid.uuid4())

              for label in seat_labels:
                  seat = self._seats[label]
                  hold = SeatHold(
                      seat=seat,
                      user_id=user_id,
                      held_until=held_until,
                      hold_id=f"{hold_id}_{label}",
                  )
                  self._holds[hold.hold_id] = hold
                  self._seat_hold_map[label] = hold.hold_id
                  self._seat_status[label] = SeatStatus.HELD

              # Return the first hold as the "session hold" reference
              first_hold = list(self._holds.values())[-len(seat_labels)]
              return first_hold

      def _expire_holds(self):
          """Called inside lock — remove holds whose timer expired."""
          now = datetime.now()
          expired_hold_ids = [
              hold_id for hold_id, hold in self._holds.items()
              if hold.held_until < now
          ]
          for hold_id in expired_hold_ids:
              hold = self._holds.pop(hold_id)
              label = hold.seat.label()
              # Only release if the seat is still mapped to this hold
              if self._seat_hold_map.get(label) == hold_id:
                  del self._seat_hold_map[label]
                  self._seat_status[label] = SeatStatus.AVAILABLE

  Why _expire_holds() called inside the lock?
  Because _seat_status is shared mutable state. If you expire outside the lock, another thread might read HELD for a seat that should be AVAILABLE.

  ---
  Step 6: Book Seats (Payment Confirmed)

      def book_seats(
          self,
          seat_labels: List[str],
          user_id: str,
          hold_ids: Optional[List[str]] = None,
      ) -> Optional[Reservation]:
          """
          Confirm booking. Seats must be HELD by this user (or AVAILABLE for direct booking).
          Returns Reservation on success, None on failure.
          """
          with self._lock:
              self._expire_holds()

              # Validate all seats
              for label in seat_labels:
                  if label not in self._seats:
                      return None
                  status = self._seat_status[label]

                  if status == SeatStatus.HELD:
                      # Verify the hold belongs to this user
                      hold_id = self._seat_hold_map.get(label)
                      hold = self._holds.get(hold_id)
                      if not hold or hold.user_id != user_id:
                          return None  # held by someone else
                  elif status != SeatStatus.AVAILABLE:
                      return None  # BOOKED or BLOCKED

              # Calculate price
              total = sum(
                  self.price_map.get(self._seats[label].seat_type, 12.0)
                  for label in seat_labels
              )

              # Confirm booking
              seats = [self._seats[label] for label in seat_labels]
              confirmation_id = str(uuid.uuid4())[:8].upper()
              reservation = Reservation(
                  confirmation_id=confirmation_id,
                  showtime_id=self.showtime_id,
                  user_id=user_id,
                  seats=seats,
                  total_price=total,
                  booked_at=datetime.now(),
              )

              # Update state
              for label in seat_labels:
                  hold_id = self._seat_hold_map.pop(label, None)
                  if hold_id:
                      self._holds.pop(hold_id, None)
                  self._seat_status[label] = SeatStatus.BOOKED

              self._reservations[confirmation_id] = reservation
              return reservation

  ---
  Step 7: Cancel Reservation

      def cancel(self, confirmation_id: str, user_id: str) -> bool:
          """
          Cancel a confirmed reservation. Releases seats back to AVAILABLE.
          Returns True if cancelled, False if not found / not owner.
          """
          with self._lock:
              reservation = self._reservations.get(confirmation_id)
              if not reservation:
                  return False
              if reservation.user_id != user_id:
                  return False    # can't cancel someone else's booking
              if reservation.status == "CANCELLED":
                  return False    # already cancelled

              reservation.status = "CANCELLED"
              for seat in reservation.seats:
                  self._seat_status[seat.label()] = SeatStatus.AVAILABLE
              return True

      def available_seats(self) -> List[Seat]:
          """Snapshot of available seats (safe read with lock)."""
          with self._lock:
              self._expire_holds()
              return [
                  self._seats[label]
                  for label, status in self._seat_status.items()
                  if status == SeatStatus.AVAILABLE
              ]

