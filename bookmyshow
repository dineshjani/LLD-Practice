  Step 11: Concurrent Stress Test                                                                                                                                                                               
                  
  import threading

  # Two users racing for the same seats                                                                                                                                                                         
  results = []
  barrier = threading.Barrier(2)     # both threads start simultaneously                                                                                                                                        
                                                                                                                                                                                                                
  def user_books(user_id, seat_labels):
      barrier.wait()                  # wait until both ready — true race                                                                                                                                       
      r = system.book_seats("S1", seat_labels, user_id=user_id)                                                                                                                                                 
      results.append((user_id, r))                                                                                                                                                                              
                                                                                                                                                                                                                
  # Reset state for clean test                                                                                                                                                                                  
  show2 = Showtime("S2", avatar, "T1", datetime(2026, 3, 27, 21, 0), seats,
                   {"STANDARD": 250.0, "PREMIUM": 400.0})                                                                                                                                                       
  system.add_showtime(show2)
                                                                                                                                                                                                                
  t1 = threading.Thread(target=user_books, args=("U10", ["C1", "C2"]))                                                                                                                                          
  t2 = threading.Thread(target=user_books, args=("U11", ["C1", "C3"]))  # both want C1!
                                                                                                                                                                                                                
  t1.start(); t2.start()
  t1.join(); t2.join()                                                                                                                                                                                          
                  
  for user, res in results:                                                                                                                                                                                     
      print(f"{user}: {'SUCCESS' if res else 'FAILED'}")
  # Exactly one succeeds, one fails — the lock guarantees this.                                                                                                                                                 
                                                                                                                                                                                                                
