  Step 9: BookingSystem — The Orchestrator

  class BookingSystem:
      """
      Top-level facade. Holds indexes for fast lookup.
      Thread-safe: each Showtime has its own lock; BookingSystem
      only needs a lock for its own index mutations.
      """

      def __init__(self):
          self._lock = threading.Lock()
          self._movies: Dict[str, Movie] = {}             # movie_id → Movie
          self._theaters: Dict[str, Theater] = {}         # theater_id → Theater
          self._showtimes: Dict[str, Showtime] = {}       # showtime_id → Showtime

          # Indexes for fast search
          self._movie_title_index: Dict[str, List[str]] = {}      # title_lower → [movie_id]
          self._theater_showtimes: Dict[str, List[str]] = {}      # theater_id → [showtime_id]
          self._movie_showtimes: Dict[str, List[str]] = {}        # movie_id → [showtime_id]
          self._user_reservations: Dict[str, List[str]] = {}      # user_id → [confirmation_id+showtime_id]

  Why build indexes?
  - search_movies("Avatar") → without index: scan all movies O(n). With title index: O(1) hash lookup.
  - get_showtimes_for_movie(movie_id) → without index: scan all showtimes. With index: O(1).

      # --- Admin: Add content ---

      def add_movie(self, movie: Movie):
          with self._lock:
              self._movies[movie.id] = movie
              key = movie.title.lower()
              self._movie_title_index.setdefault(key, []).append(movie.id)
              self._movie_showtimes.setdefault(movie.id, [])

      def add_theater(self, theater: Theater):
          with self._lock:
              self._theaters[theater.theater_id] = theater
              self._theater_showtimes.setdefault(theater.theater_id, [])

      def add_showtime(self, showtime: Showtime):
          with self._lock:
              self._showtimes[showtime.showtime_id] = showtime
              self._theater_showtimes.setdefault(showtime.theater_id, []).append(showtime.showtime_id)
              self._movie_showtimes.setdefault(showtime.movie.id, []).append(showtime.showtime_id)

      # --- User-facing: Search ---

      def search_movies(self, title: str) -> List[Movie]:
          """Case-insensitive title search."""
          key = title.lower()
          with self._lock:
              ids = self._movie_title_index.get(key, [])
              return [self._movies[mid] for mid in ids if mid in self._movies]

      def get_showtimes_for_movie(
          self,
          movie_id: str,
          date: Optional[datetime] = None,
      ) -> List[Showtime]:
          with self._lock:
              ids = self._movie_showtimes.get(movie_id, [])
              shows = [self._showtimes[sid] for sid in ids if sid in self._showtimes]

          if date:
              shows = [
                  s for s in shows
                  if s.start_time.date() == date.date()
              ]
          return shows

      def get_showtimes_at_theater(self, theater_id: str) -> List[Showtime]:
          with self._lock:
              ids = self._theater_showtimes.get(theater_id, [])
              return [self._showtimes[sid] for sid in ids if sid in self._showtimes]

      # --- User-facing: Booking flow ---

      def hold_seats(
          self, showtime_id: str, seat_labels: List[str], user_id: str
      ) -> Optional[SeatHold]:
          showtime = self._showtimes.get(showtime_id)
          if not showtime:
              return None
          return showtime.hold_seats(seat_labels, user_id)

      def book_seats(
          self,
          showtime_id: str,
          seat_labels: List[str],
          user_id: str,
      ) -> Optional[Reservation]:
          showtime = self._showtimes.get(showtime_id)
          if not showtime:
              return None
          reservation = showtime.book_seats(seat_labels, user_id)
          if reservation:
              with self._lock:
                  self._user_reservations.setdefault(user_id, []).append(
                      f"{showtime_id}::{reservation.confirmation_id}"
                  )
          return reservation

      def cancel_reservation(
          self, showtime_id: str, confirmation_id: str, user_id: str
      ) -> bool:
          showtime = self._showtimes.get(showtime_id)
          if not showtime:
              return False
          return showtime.cancel(confirmation_id, user_id)

      def get_available_seats(self, showtime_id: str) -> List[Seat]:
          showtime = self._showtimes.get(showtime_id)
          if not showtime:
              return []
          return showtime.available_seats()

