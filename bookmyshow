  Step 3: Reservation (Confirmation)

  @dataclass
  class Reservation:
      confirmation_id: str
      showtime_id: str
      user_id: str
      seats: List[Seat]
      total_price: float
      booked_at: datetime
      status: str = "CONFIRMED"   # "CONFIRMED" | "CANCELLED"

      def receipt(self) -> str:
          seat_labels = ", ".join(s.label() for s in self.seats)
          return (
              f"Booking {self.confirmation_id}\n"
              f"Seats: {seat_labels}\n"
              f"Total: ${self.total_price:.2f}\n"
              f"Status: {self.status}"
          )

